# Flask config
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# Database (get the real value from Vercel Postgres dashboard)
POSTGRES_URL=postgres://user:password@host:port/dbname

# Firebase Admin SDK
# Paste the full service account JSON as a single-line string here
# Ask the backend lead for the actual value — never commit the real one
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# Firebase client config (used in admin login frontend, safe to be public)
FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id