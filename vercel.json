{
  "builds": [
    { "src": "/robots.txt", "dest": "/static/robots.txt" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ],
  "routes": [
    { "src": "/sitemap.xml", "dest": "/static/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/static/robots.txt" },
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/(.*)", "dest": "api/index.py" }
  ]
}